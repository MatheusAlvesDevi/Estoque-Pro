    "/api/supply": {
      "get": {
        "tags": ["Fornecedores"],
        "summary": "Listar todos os fornecedores",
        "description": "Retorna uma lista completa de todos os fornecedores cadastrados",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de fornecedores retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Supplier"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Fornecedores"],
        "summary": "Criar novo fornecedor",
        "description": "Cadastra um novo fornecedor no sistema",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "CNPJ", "tel", "email"],
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Samsung Electronics"
                  },
                  "CNPJ": {
                    "type": "string",
                    "example": "12.345.678/0001-00"
                  },
                  "tel": {
                    "type": "string",
                    "example": "(11) 99999-0000"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "contato@samsung.com"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Fornecedor criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Supplier"
                }
              }
            }
          }
        }
      }
    },
    "/api/supply/{id}": {
      "get": {
        "tags": ["Fornecedores"],
        "summary": "Obter fornecedor por ID",
        "description": "Retorna os detalhes de um fornecedor específico",
        "security": [
          {
            "bearerToken": []
          }
        ],
        "parameters": [
          {
